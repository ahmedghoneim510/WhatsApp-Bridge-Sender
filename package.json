{
  "name": "whatsapp-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:db": "node scripts/start-with-db.js",
    "dev": "node --watch src/index.js",
    "test": "node scripts/test-api.js",
    "db:setup": "node scripts/setup-database.js",
    "db:migrate": "node scripts/setup-database.js",
    "db:fresh": "node scripts/migrate-fresh.js",
    "db:status": "node scripts/db-status.js",
    "docker:build": "docker build -t whatsapp-bridge .",
    "docker:run": "docker run -p 3000:3000 -v $(pwd)/data:/app/data whatsapp-bridge"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.0",
    "axios": "^1.6.8",
    "baileys_helpers": "^1.0.16",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "mysql2": "^3.9.1",
    "pino": "^8.21.0",
    "pino-http": "^8.6.1",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0"
  }
}
