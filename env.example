# Server Configuration
PORT=3000
LOG_LEVEL=info

# Security - API Authentication (اختياري - اتركه فارغاً للـ development)
# إذا كان محدد، يجب إرسال API key في header: X-API-Key
API_KEY=

# Session Configuration
SESSION_DIR=data/sessions

# Idempotency Settings (prevents duplicate webhook events)
IDEMPOTENCY_TTL_MS=600000  # 10 minutes
IDEMPOTENCY_MAX_KEYS=20000

# Message Store Settings (for poll votes and message retrieval)
MESSAGE_STORE_TTL_MS=3600000  # 1 hour
MESSAGE_STORE_MAX=5000

# CORS Settings (for dashboard access)
# يمكن إضافة عدة مصادر مفصولة بفاصلة: http://localhost:3000,http://localhost:3001,https://example.com
# ملاحظة: Dashboard يعمل على نفس البورت (3000) لذلك سيتم السماح تلقائياً
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Webhook Settings
WEBHOOK_TIMEOUT_MS=10000  # 10 seconds
WEBHOOK_RETRIES=3  # عدد محاولات إعادة الإرسال

# Bulk Messaging Settings
MAX_BULK_SIZE=100  # الحد الأقصى لعدد المستلمين في bulk message